load("@rules_shell//shell:sh_test.bzl", "sh_test")
load("@rules_python//python:defs.bzl", "py_binary")
load("@tx-kit-ext//rules:multi_app.bzl", "multi_app")
load("@tx-kit-ext//rules:exec_binary.bzl", "exec_binary")

# Client on target platform with execution platform wrapper
multi_app(
    name = "client",
    srcs = ["client_test.cpp"],
    args = ["--gtest_output=xml:client_test_results.xml"],
    deps = [
        "//src/pkg/app-asio",
        "//src/pkg/http",
        "@googletest//:gtest_main",
    ],
)

# Server on execution platform
alias(
    name = "server",
    actual = "//test/pkg/http/stub:stub_server",
)
exec_binary(
    name = "server.cmd",
    binary = ":server",
)

# Bridge to control server lifecycle and run client test
py_binary(
    name = "bridge",
    srcs = ["//test/pkg/http/integration_bridge:integration_bridge.py"],
    main = "integration_bridge.py",
)
exec_binary(
    name = "bridge.cmd",
    binary = ":bridge",
)

# Glue all together
sh_test(
    name = "http.cmd",
    srcs = ["@tx-kit-ext//runner:sh_wrapper"],
    data = [
        "//:runner",
        ":bridge.cmd",
        ":server.cmd",
        ":client",
    ],
    args = [
        "$(location //:runner)",
        "$(location :bridge.cmd)",
        "$(location :server.cmd)",
        "$(location :client)",
    ],
    tags = [
        "int",  # int: integration test (longer running, external dependencies, etc.)
        "exclusive",  # exclusive: prevent parallel execution with other tests (port conflicts)
        "requires-network",  # requires-network: test uses network (local server on specific port)
    ],
)
test_suite(
    name = "http",
    tests = [":http.cmd"],
)

load("@tx-kit-ext//rules:multi_app.bzl", "multi_app")
load("//test/integration:integration.bzl", "integration_test")

# Client on target platform
multi_app(
    name = "client",
    srcs = glob(["*.cpp"]),
    args = ["--gtest_output=xml:client_test_results.xml"],
    deps = [
        "//pkg/app",
        "//pkg/asio",
        "//pkg/http",
        "@googletest//:gtest_main",
    ],
)

integration_test(
    name = "http",
    client = ":client",
    server = "//test/pkg/http/stub:stub_server",
)

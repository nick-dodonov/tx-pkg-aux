load("@tx-kit-ext//rules:embedded.bzl", "embedded_files")
load("@tx-kit-ext//rules:multi_app.bzl", "multi_test")

filegroup(
    name = "test_data",
    srcs = ["data/test.txt"],
)

embedded_files(
    name = "embedded_test_data",
    files_to_dir = {
        "data/test.txt": "test_data",
    },
)

multi_test(
    name = "fs",
    srcs = glob(["*.cpp"]),

    data = [":test_data"],
    embedded_data = [":embedded_test_data"],
    deps = [
        "//pkg/app",
        "//pkg/fs",
        "@googletest//:gtest",
    ],
)

load("@tx-kit-ext//rules:multi_app.bzl", "multi_test")

multi_test(
    name = "ws-sig-in-process",
    srcs = ["DcWsSig.InProcess.Test.cpp"],
    cxxopts = ["-fexceptions"],
    platforms = [
        "host",
        "droid",
    ],
    deps = [
        "//pkg/rtt",
        "//pkg/rtt/rtc",
        "@googletest//:gtest_main",
    ],
)

multi_test(
    name = "ws-sig-client",
    srcs = ["WsSigClient.Integration.Test.cpp"],
    cxxopts = ["-fexceptions"],
    linkopts = select({
        "@platforms//cpu:wasm32": ["-sASYNCIFY=1"],
        "//conditions:default": [],
    }),
    tags = ["manual"],  # requires the server to be running
    deps = [
        "//pkg/rtt/rtc",
        "@googletest//:gtest_main",
    ],
)

load("@tx-kit-ext//rules:multi_app.bzl", "multi_test")

multi_test(
    name = "rtc",
    srcs = glob(
        [
            "*.cpp",
            "*.h",
        ],
        allow_empty = True,
        exclude = ["WsSigClientIntegration.Test.cpp"],
    ),
    cxxopts = ["-fexceptions"],
    platforms = [
        "host",
        "droid",
    ],
    deps = [
        "//pkg/rtt",
        "//pkg/rtt/rtc",
        "@googletest//:gtest_main",
    ],
)

multi_test(
    name = "rtc_integration",
    srcs = ["WsSigClientIntegration.Test.cpp"],
    cxxopts = ["-fexceptions"],
    linkopts = select({
        "@platforms//cpu:wasm32": ["-sASYNCIFY=1"],
        "//conditions:default": [],
    }),
    deps = [
        "//pkg/rtt/rtc",
        "@googletest//:gtest_main",
    ],
)

load("@tx-kit-ext//rules:multi_app.bzl", "multi_app")

multi_app(
    name = "http-nghttp2",
    srcs = glob(["**/*.cpp", "**/*.h"]),
    deps = [
        "@tx-pkg-aux//src/pkg-boot",
        "@nghttp2//:nghttp2",
        "@boringssl//:ssl",
    ],
    linkopts = select({
        "@platforms//os:windows": ["ws2_32.lib"],
        "//conditions:default": [],
    }),
    platforms = ["host"],
)

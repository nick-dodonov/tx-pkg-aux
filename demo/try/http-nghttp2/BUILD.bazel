load("@tx-kit-ext//rules:multi_app.bzl", "multi_app")

multi_app(
    name = "http-nghttp2",
    srcs = glob([
        "**/*.cpp",
        "**/*.h",
    ]),
    linkopts = select({
        "@platforms//os:windows": ["ws2_32.lib"],
        "//conditions:default": [],
    }),
    platforms = ["host"],
    deps = [
        "@boringssl//:ssl",
        "@nghttp2",
        "@tx-pkg-aux//pkg/boot",
    ],
)
